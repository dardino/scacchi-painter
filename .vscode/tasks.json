{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dev: full web stack",
            "type": "shell",
            "command": "pnpm",
            "args": [
                "dev"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "runOptions": {
                "runOn": "default"
            },
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}/Core"
            },
            "label": "build",
            "command": "dotnet build",
            "type": "shell",
            "group": "build",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "type": "func",
            "label": "func: host start",
            "command": "host start",
            "problemMatcher": "$func-node-watch",
            "isBackground": true,
            "dependsOn": "pnpm watch (functions)",
            "options": {
                "cwd": "${workspaceFolder}/Gui/sp-gui-angular/api"
            }
        },
        {
            "type": "shell",
            "label": "pnpm build (functions)",
            "command": "pnpm build",
            "dependsOn": "pnpm clean (functions)",
            "problemMatcher": "$tsc",
            "options": {
                "cwd": "${workspaceFolder}/Gui/sp-gui-angular/api"
            }
        },
        {
            "type": "shell",
            "label": "pnpm watch (functions)",
            "command": "pnpm watch",
            "dependsOn": "pnpm clean (functions)",
            "problemMatcher": "$tsc-watch",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "options": {
                "cwd": "${workspaceFolder}/Gui/sp-gui-angular/api"
            }
        },
        {
            "type": "shell",
            "label": "pnpm install (functions)",
            "command": "pnpm install --frozen-lockfile",
            "options": {
                "cwd": "${workspaceFolder}/Gui/sp-gui-angular/api"
            }
        },
        {
            "type": "shell",
            "label": "pnpm prune (functions)",
            "command": "pnpm prune --prod",
            "dependsOn": "pnpm build (functions)",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/Gui/sp-gui-angular/api"
            }
        },
        {
            "type": "shell",
            "label": "pnpm clean (functions)",
            "command": "pnpm clean",
            "dependsOn": "pnpm install (functions)",
            "options": {
                "cwd": "${workspaceFolder}/Gui/sp-gui-angular/api"
            }
        }
    ]
}

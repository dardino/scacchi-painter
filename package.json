{
  "name": "scacchi-painter-root",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "node ./scripts/dev-runner.mjs",
    "dev:web": "node ./scripts/dev-runner.mjs web",
    "dev:api": "node ./scripts/dev-runner.mjs api",
    "dev:angular": "node ./scripts/dev-runner.mjs angular",
    "dev:swa": "node ./scripts/dev-runner.mjs swa",
    "build:web": "pnpm --dir Gui/sp-gui-angular build:Azure",
    "test:web": "pnpm --dir Gui/sp-gui-angular test:ci",
    "lint:web": "pnpm --dir Gui/sp-gui-angular lint",
    "build:corejs": "pnpm --dir CoreJS build",
    "test:corejs": "pnpm --dir CoreJS test",
    "build:tauri": "pnpm --dir Gui/sp-gui tauri build"
  },
  "pnpm": {
    "overrides": {
      "prosemirror-model": "1.21.0"
    },
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "lmdb",
      "msgpackr-extract",
      "optipng-bin",
      "sharp",
      "unrs-resolver",
      "zopflipng-bin"
    ],
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
